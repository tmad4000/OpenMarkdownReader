{
  "name": "open-markdown-reader",
  "productName": "OpenMarkdownReader",
  "version": "1.0.0",
  "description": "A beautiful, open-source Markdown file reader and editor for Mac",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/generate-build-info.js && electron .",
    "build": "node scripts/generate-build-info.js && electron-builder",
    "build:mac": "node scripts/generate-build-info.js && electron-builder --mac",
    "build:dmg": "node scripts/generate-build-info.js && electron-builder --mac dmg",
    "build:mas": "node scripts/generate-build-info.js && electron-builder --mac mas"
  },
  "keywords": [
    "markdown",
    "reader",
    "editor",
    "electron",
    "open-source"
  ],
  "author": "Jacob Cole",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tmad4000/OpenMarkdownReader.git"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "easymde": "^2.20.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.jacobcole.openmarkdownreader",
    "productName": "OpenMarkdownReader",
    "extraResources": [
      {
        "from": "cli.sh",
        "to": "cli.sh"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": "IdeaFlow, Inc. (JESMXK96LG)",
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "title": "OpenMarkdownReader",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "mas": {
      "identity": "Apple Distribution: IdeaFlow, Inc. (JESMXK96LG)",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/embedded.provisionprofile"
    },
    "pkg": {
      "identity": "B2D608D3556482EE684046BF24F561FB62FA81B4"
    },
    "files": [
      "**/*",
      "build-info.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}",
      "!.beads/**",
      "!.gemini-clipboard/**",
      "!scripts/**"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "icon": "build/icon.icns"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "icon": "build/icon.icns"
      },
      {
        "ext": "mdown",
        "name": "Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "icon": "build/icon.icns"
      },
      {
        "ext": "mkd",
        "name": "Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "icon": "build/icon.icns"
      },
      {
        "ext": "txt",
        "name": "Text Document",
        "role": "Editor",
        "mimeType": "text/plain"
      },
      {
        "ext": "json",
        "name": "JSON Document",
        "role": "Viewer",
        "mimeType": "application/json"
      },
      {
        "ext": "yaml",
        "name": "YAML Document",
        "role": "Viewer",
        "mimeType": "text/yaml"
      },
      {
        "ext": "yml",
        "name": "YAML Document",
        "role": "Viewer",
        "mimeType": "text/yaml"
      },
      {
        "ext": "toml",
        "name": "TOML Document",
        "role": "Viewer",
        "mimeType": "text/plain"
      },
      {
        "ext": "xml",
        "name": "XML Document",
        "role": "Viewer",
        "mimeType": "text/xml"
      },
      {
        "ext": "csv",
        "name": "CSV Document",
        "role": "Viewer",
        "mimeType": "text/csv"
      },
      {
        "ext": "log",
        "name": "Log File",
        "role": "Viewer",
        "mimeType": "text/plain"
      },
      {
        "ext": "rst",
        "name": "reStructuredText Document",
        "role": "Viewer",
        "mimeType": "text/plain"
      },
      {
        "ext": "org",
        "name": "Org Document",
        "role": "Viewer",
        "mimeType": "text/plain"
      },
      {
        "ext": "adoc",
        "name": "AsciiDoc Document",
        "role": "Viewer",
        "mimeType": "text/plain"
      }
    ]
  }
}
